---
import MainLayout from '../../layouts/MainLayout.astro';
import GatinderApp from '../../components/react/GatinderApp';
import { getSession } from '../../lib/auth';

const session = await getSession(Astro.cookies);
---

<MainLayout title="Gatinder">
  <div class="mb-8 text-center">
    <h1 class="font-display text-4xl font-bold">Gatinder</h1>
    <p class="mt-2 font-semibold text-ink-500">
      Desliza o usa los botones. Si ambos maúllan… ¡Hay Match!
    </p>
    {
      session?.activeCat && (
        <p class="mt-2 text-sm font-bold text-mint-600">Jugando como {session.activeCat.name}</p>
      )
    }
  </div>
  <GatinderApp client:load canPlay={Boolean(session?.activeCat)} />
</MainLayout>
