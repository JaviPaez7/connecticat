---
import MainLayout from '../../layouts/MainLayout.astro';
import AuthForm from '../../components/react/AuthForm';
import { getSession } from '../../lib/auth';

const session = await getSession(Astro.cookies);
if (session) return Astro.redirect('/perfil');
---

<MainLayout title="Entrar">
  <div class="mx-auto max-w-md">
    <h1 class="font-display text-4xl font-bold text-ink-900">Entrar</h1>
    <p class="mt-2 font-semibold text-ink-500">
      Demo: <code class="rounded bg-white/80 px-1">luna@connecticat.dev</code> /
      <code class="rounded bg-white/80 px-1">miau1234</code>
    </p>
    <div class="mt-8 rounded-3xl border border-white/70 bg-white/70 p-6 shadow-sm backdrop-blur">
      <AuthForm client:load mode="login" />
    </div>
    <p class="mt-4 text-sm font-semibold text-ink-600">
      ¿Nuevo? <a href="/auth/registro" class="font-bold text-coral-600 hover:underline">Créate una cuenta</a>
    </p>
  </div>
</MainLayout>
