---
import MainLayout from '../../layouts/MainLayout.astro';
import AuthForm from '../../components/react/AuthForm';
import { getSession } from '../../lib/auth';

const session = await getSession(Astro.cookies);
if (session) return Astro.redirect('/perfil');
---

<MainLayout title="Registro">
  <div class="mx-auto max-w-md">
    <h1 class="font-display text-4xl font-bold text-ink-900">Crear cuenta</h1>
    <p class="mt-2 font-semibold text-ink-500">Únete a Connecticat y crea perfiles de gatos.</p>
    <div class="mt-8 rounded-3xl border border-white/70 bg-white/70 p-6 shadow-sm backdrop-blur">
      <AuthForm client:load mode="register" />
    </div>
    <p class="mt-4 text-sm font-semibold text-ink-600">
      ¿Ya tienes cuenta? <a href="/auth/login" class="font-bold text-coral-600 hover:underline">Entrar</a>
    </p>
  </div>
</MainLayout>
