---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';
import HeroLanding from '../components/react/HeroLanding';
import FeatureSections from '../components/react/FeatureSections';
import { getSession } from '../lib/auth';

const session = await getSession(Astro.cookies);
---

<BaseLayout>
  <div class="flex min-h-svh flex-col bg-ink-900">
    <div class="absolute inset-x-0 top-0 z-50">
      <Navbar session={session} overlay />
    </div>
    <HeroLanding client:load />
    <FeatureSections client:load />
    <Footer />
  </div>
</BaseLayout>
