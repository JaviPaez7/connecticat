---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMark from '../components/astro/BrandMark.astro';
import HeroSpark from '../components/react/HeroSpark';
import { navLinks, site } from '../lib/site';
---

<BaseLayout>
  <main class="relative overflow-hidden">
    <!-- Atmospheric blobs -->
    <div
      class="pointer-events-none absolute -left-24 top-16 h-72 w-72 animate-float rounded-full bg-coral-300/40 blur-3xl"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute -right-16 top-40 h-80 w-80 animate-float-delayed rounded-full bg-mint-300/35 blur-3xl"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-10 left-1/3 h-64 w-64 rounded-full bg-apricot-300/30 blur-3xl"
      aria-hidden="true"
    ></div>

    <header class="relative z-10 mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
      <BrandMark />
      <nav class="hidden items-center gap-1 md:flex" aria-label="Secciones">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="rounded-xl px-3 py-2 text-sm font-semibold text-ink-700 transition hover:bg-white/70 hover:text-coral-600"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
      <a
        href="/auth/login"
        class="rounded-xl bg-ink-900 px-4 py-2 text-sm font-bold text-white transition hover:bg-coral-600"
      >
        Entrar
      </a>
    </header>

    <section
      class="relative z-10 mx-auto flex min-h-[calc(100vh-5.5rem)] max-w-6xl flex-col items-start justify-center px-6 pb-20 pt-8"
    >
      <div class="animate-fade-up mb-6">
        <BrandMark size="lg" />
      </div>

      <h1
        class="font-display animate-fade-up-delay-1 max-w-3xl text-5xl font-bold leading-[1.05] tracking-tight text-ink-900 sm:text-6xl lg:text-7xl text-balance"
      >
        Donde los gatos
        <span
          class="animate-shimmer bg-gradient-to-r from-coral-500 via-apricot-400 to-mint-500 bg-clip-text text-transparent"
        >
          conectan
        </span>
        de verdad
      </h1>

      <p
        class="animate-fade-up-delay-2 mt-6 max-w-xl text-lg font-semibold text-ink-700 sm:text-xl text-balance"
      >
        {site.tagline}. Feed, matches, curiosidades y foro — todo con energía felina.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-4 animate-fade-up-delay-2">
        <a
          href="/auth/registro"
          class="rounded-2xl bg-gradient-to-r from-coral-500 to-apricot-400 px-6 py-3.5 text-base font-bold text-white shadow-lg shadow-coral-300/50 transition hover:scale-[1.03] hover:shadow-xl"
        >
          Crear cuenta
        </a>
        <a
          href="/gatinder"
          class="rounded-2xl border-2 border-mint-300 bg-white/60 px-6 py-3.5 text-base font-bold text-mint-700 backdrop-blur transition hover:border-mint-400 hover:bg-mint-50"
        >
          Probar Gatinder
        </a>
      </div>

      <div class="mt-10">
        <HeroSpark client:load />
      </div>

      <ul class="mt-16 grid w-full gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          [
            { href: '/feed', title: 'Catstagram', copy: 'Meows, posts y galerías' },
            { href: '/gatinder', title: 'Gatinder', copy: 'Swipe y ¡Hay Match!' },
            { href: '/curiosidades', title: 'Curiosidades', copy: 'Hábitos y tips SEO' },
            { href: '/foro', title: 'Purr-Foro', copy: 'Comunidad y votos' },
          ].map((item, i) => (
            <li>
              <a
                href={item.href}
                class="group block rounded-3xl border border-white/70 bg-white/55 p-5 shadow-sm backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-coral-200 hover:bg-white/80 hover:shadow-md"
                style={`animation: fade-up 0.7s var(--ease-smooth) ${0.35 + i * 0.08}s both`}
              >
                <h2 class="font-display text-lg font-bold text-ink-900 group-hover:text-coral-600">
                  {item.title}
                </h2>
                <p class="mt-1 text-sm font-semibold text-ink-500">{item.copy}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>
