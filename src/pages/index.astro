---
import MainLayout from '../layouts/MainLayout.astro';
import BrandMark from '../components/astro/BrandMark.astro';
import HeroSpark from '../components/react/HeroSpark';
import { site } from '../lib/site';
---

<MainLayout>
  <section class="relative overflow-hidden pb-8 pt-4">
    <div
      class="pointer-events-none absolute -left-20 top-0 h-64 w-64 animate-float rounded-full bg-coral-300/35 blur-3xl"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute -right-10 top-20 h-72 w-72 animate-float-delayed rounded-full bg-mint-300/30 blur-3xl"
      aria-hidden="true"
    ></div>

    <div class="relative animate-fade-up mb-4">
      <BrandMark size="lg" />
    </div>

    <h1
      class="font-display animate-fade-up-delay-1 max-w-3xl text-5xl font-bold leading-[1.05] tracking-tight text-ink-900 sm:text-6xl lg:text-7xl text-balance"
    >
      Donde los gatos
      <span
        class="animate-shimmer bg-gradient-to-r from-coral-500 via-apricot-400 to-mint-500 bg-clip-text text-transparent"
      >
        conectan
      </span>
      de verdad
    </h1>

    <p
      class="animate-fade-up-delay-2 mt-6 max-w-xl text-lg font-semibold text-ink-700 sm:text-xl text-balance"
    >
      {site.tagline}. Feed, matches, curiosidades y foro — todo con energía felina.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-4 animate-fade-up-delay-2">
      <a
        href="/auth/registro"
        class="rounded-2xl bg-gradient-to-r from-coral-500 to-apricot-400 px-6 py-3.5 text-base font-bold text-white shadow-lg shadow-coral-300/50 transition hover:scale-[1.03]"
      >
        Crear cuenta
      </a>
      <a
        href="/gatinder"
        class="rounded-2xl border-2 border-mint-300 bg-white/60 px-6 py-3.5 text-base font-bold text-mint-700 backdrop-blur transition hover:bg-mint-50"
      >
        Probar Gatinder
      </a>
    </div>

    <div class="mt-10">
      <HeroSpark client:load />
    </div>

    <ul class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        [
          { href: '/feed', title: 'Catstagram', copy: 'Meows, posts y galerías' },
          { href: '/gatinder', title: 'Gatinder', copy: 'Swipe y ¡Hay Match!' },
          { href: '/curiosidades', title: 'Curiosidades', copy: 'Hábitos y tips SEO' },
          { href: '/foro', title: 'Purr-Foro', copy: 'Comunidad y votos' },
        ].map((item, i) => (
          <li>
            <a
              href={item.href}
              class="group block rounded-3xl border border-white/70 bg-white/55 p-5 shadow-sm backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-coral-200 hover:bg-white/80"
              style={`animation: fade-up 0.7s var(--ease-smooth) ${0.35 + i * 0.08}s both`}
            >
              <h2 class="font-display text-lg font-bold text-ink-900 group-hover:text-coral-600">
                {item.title}
              </h2>
              <p class="mt-1 text-sm font-semibold text-ink-500">{item.copy}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</MainLayout>
