---
import MainLayout from '../../layouts/MainLayout.astro';
import { getSession } from '../../lib/auth';
import { prisma } from '../../lib/db';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/auth/login');

const posts = session.activeCat
  ? await prisma.post.findMany({
      where: { catProfileId: session.activeCat.id },
      orderBy: { createdAt: 'desc' },
      take: 12,
    })
  : [];

const matches = session.activeCat
  ? await prisma.match.findMany({
      where: {
        OR: [{ catOneId: session.activeCat.id }, { catTwoId: session.activeCat.id }],
      },
      include: { catOne: true, catTwo: true },
      orderBy: { createdAt: 'desc' },
      take: 8,
    })
  : [];
---

<MainLayout title="Perfil">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="font-display text-4xl font-bold">Tus gatos</h1>
      <p class="mt-1 font-semibold text-ink-500">{session.user.email}</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a
        href="/perfil/nuevo"
        class="rounded-2xl bg-gradient-to-r from-coral-500 to-apricot-400 px-4 py-2.5 text-sm font-bold text-white"
      >
        + Nuevo gato
      </a>
      <form method="POST" action="/api/auth/logout" id="logout-form">
        <button
          type="button"
          id="logout-btn"
          class="rounded-2xl border-2 border-ink-200 bg-white/70 px-4 py-2.5 text-sm font-bold text-ink-700"
        >
          Cerrar sesión
        </button>
      </form>
    </div>
  </div>

  {
    session.cats.length === 0 ? (
      <div class="mt-10 rounded-3xl bg-white/70 p-8 text-center">
        <p class="font-semibold text-ink-600">Aún no tienes perfiles de gato.</p>
        <a href="/perfil/nuevo" class="mt-4 inline-block font-bold text-coral-600 hover:underline">
          Crear el primero →
        </a>
      </div>
    ) : (
      <ul class="mt-8 grid gap-4 sm:grid-cols-2">
        {session.cats.map((cat) => (
          <li
            class:list={[
              'rounded-3xl border bg-white/70 p-5 backdrop-blur transition',
              session.activeCat?.id === cat.id
                ? 'border-coral-300 ring-2 ring-coral-200'
                : 'border-white/70',
            ]}
          >
            <div class="flex gap-4">
              <img src={cat.avatarUrl} alt="" class="h-20 w-20 rounded-2xl object-cover" />
              <div class="min-w-0 flex-1">
                <h2 class="font-display text-xl font-bold">{cat.name}</h2>
                <p class="text-sm font-bold text-mint-600">
                  {cat.breed} · {cat.age} años
                </p>
                <p class="mt-1 line-clamp-2 text-sm font-semibold text-ink-600">{cat.bio}</p>
                {session.activeCat?.id !== cat.id && (
                  <button
                    type="button"
                    class="activate-cat mt-3 text-sm font-bold text-coral-600 hover:underline"
                    data-cat-id={cat.id}
                  >
                    Usar este perfil
                  </button>
                )}
                {session.activeCat?.id === cat.id && (
                  <p class="mt-3 text-xs font-bold uppercase tracking-wide text-coral-500">Activo</p>
                )}
              </div>
            </div>
            <div class="mt-3 flex flex-wrap gap-2">
              {cat.interests.map((i) => (
                <span class="rounded-full bg-apricot-100 px-2.5 py-1 text-xs font-bold text-apricot-500">
                  {i}
                </span>
              ))}
            </div>
          </li>
        ))}
      </ul>
    )
  }

  {
    session.activeCat && (
      <>
        <h2 class="font-display mt-12 text-2xl font-bold">Galería de {session.activeCat.name}</h2>
        {posts.length === 0 ? (
          <p class="mt-3 font-semibold text-ink-500">
            Sin fotos aún. Publica en <a href="/feed" class="text-coral-600 hover:underline">Catstagram</a>.
          </p>
        ) : (
          <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3">
            {posts.map((p) => (
              <img src={p.imageUrl} alt={p.caption} class="aspect-square rounded-2xl object-cover" />
            ))}
          </div>
        )}

        <h2 class="font-display mt-12 text-2xl font-bold">Matches recientes</h2>
        {matches.length === 0 ? (
          <p class="mt-3 font-semibold text-ink-500">
            Aún no hay matches. Prueba <a href="/gatinder" class="text-coral-600 hover:underline">Gatinder</a>.
          </p>
        ) : (
          <ul class="mt-4 flex flex-wrap gap-3">
            {matches.map((m) => {
              const other = m.catOneId === session.activeCat!.id ? m.catTwo : m.catOne;
              return (
                <li class="flex items-center gap-2 rounded-2xl bg-white/70 px-3 py-2">
                  <img src={other.avatarUrl} alt="" class="h-10 w-10 rounded-full object-cover" />
                  <span class="font-bold">{other.name}</span>
                </li>
              );
            })}
          </ul>
        )}
      </>
    )
  }
</MainLayout>

<script>
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });

  document.querySelectorAll('.activate-cat').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const catId = (btn as HTMLElement).dataset.catId;
      await fetch('/api/cats/active', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ catId }),
      });
      window.location.reload();
    });
  });
</script>
