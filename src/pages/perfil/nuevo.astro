---
import MainLayout from '../../layouts/MainLayout.astro';
import CatProfileForm from '../../components/react/CatProfileForm';
import { getSession } from '../../lib/auth';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/auth/login');
---

<MainLayout title="Nuevo gato">
  <div class="mx-auto max-w-lg">
    <h1 class="font-display text-4xl font-bold">Nuevo perfil de gato</h1>
    <p class="mt-2 font-semibold text-ink-500">
      Cada usuario puede gestionar varios gatos en Connecticat.
    </p>
    <div class="mt-8 rounded-3xl border border-white/70 bg-white/70 p-6 backdrop-blur">
      <CatProfileForm client:load />
    </div>
  </div>
</MainLayout>
