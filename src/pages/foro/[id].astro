---
import MainLayout from '../../layouts/MainLayout.astro';
import { ForumReplyForm, VoteButtons } from '../../components/react/ForumApp';
import { getSession } from '../../lib/auth';
import { prisma } from '../../lib/db';

const session = await getSession(Astro.cookies);
const id = Astro.params.id!;

const thread = await prisma.forumThread.findUnique({
  where: { id },
  include: {
    catProfile: true,
    replies: {
      orderBy: { createdAt: 'asc' },
      include: {
        catProfile: true,
        votes: true,
      },
    },
  },
});

if (!thread) return Astro.redirect('/foro');

const labels: Record<string, string> = {
  salud: 'Dudas de salud',
  anecdotas: 'Anécdotas',
  productos: 'Productos',
};
---

<MainLayout title={thread.title}>
  <a href="/foro" class="text-sm font-bold text-coral-600 hover:underline">← Volver al foro</a>

  <article class="mt-4 rounded-3xl border border-white/70 bg-white/75 p-6 backdrop-blur">
    <p class="text-xs font-bold uppercase tracking-wide text-mint-600">{labels[thread.category]}</p>
    <h1 class="font-display mt-2 text-3xl font-bold">{thread.title}</h1>
    <div class="mt-3 flex items-center gap-2">
      <img src={thread.catProfile.avatarUrl} alt="" class="h-9 w-9 rounded-full object-cover" />
      <span class="font-bold">{thread.catProfile.name}</span>
    </div>
    <p class="mt-4 whitespace-pre-wrap font-semibold text-ink-700">{thread.content}</p>
    {
      thread.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {thread.tags.map((tag) => (
            <span class="rounded-full bg-sky-100 px-2.5 py-1 text-xs font-bold text-sky-500">#{tag}</span>
          ))}
        </div>
      )
    }
  </article>

  <h2 class="font-display mt-10 text-2xl font-bold">Respuestas ({thread.replies.length})</h2>
  <ul class="mt-4 space-y-3">
    {
      thread.replies.map((r) => {
        const score = r.votes.reduce((s, v) => s + v.value, 0);
        const mine = session?.activeCat
          ? (r.votes.find((v) => v.catProfileId === session.activeCat!.id)?.value ?? 0)
          : 0;
        return (
          <li class="flex gap-3 rounded-3xl border border-white/70 bg-white/70 p-4">
            <VoteButtons
              client:visible
              replyId={r.id}
              initialScore={score}
              initialMine={mine}
              canVote={Boolean(session?.activeCat)}
            />
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <img src={r.catProfile.avatarUrl} alt="" class="h-8 w-8 rounded-full object-cover" />
                <span class="font-bold">{r.catProfile.name}</span>
              </div>
              <p class="mt-2 whitespace-pre-wrap text-sm font-semibold text-ink-700">{r.content}</p>
            </div>
          </li>
        );
      })
    }
  </ul>

  <ForumReplyForm client:load threadId={thread.id} canPost={Boolean(session?.activeCat)} />
</MainLayout>
