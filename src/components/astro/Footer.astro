---
import BrandMark from './BrandMark.astro';
import { site } from '../../lib/site';
---

<footer class="mt-auto border-t border-white/60 bg-white/50 backdrop-blur">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-10 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <BrandMark size="sm" />
      <p class="mt-3 max-w-sm text-sm font-semibold text-ink-500">
        {site.tagline}
      </p>
    </div>
    <div class="text-sm font-semibold text-ink-500">
      <p>
        <a class="text-coral-600 hover:underline" href={site.url}>{site.url.replace('https://', '')}</a>
      </p>
      <p class="mt-1">Hecho con 🐾 para la comunidad felina</p>
    </div>
  </div>
</footer>
