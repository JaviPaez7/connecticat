---
import BrandMark from './BrandMark.astro';
import { site } from '../../lib/site';
---

<footer class="relative mt-auto overflow-hidden border-t border-white/10 bg-ink-900 text-white">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(800px_280px_at_15%_0%,rgba(249,112,104,0.28),transparent_55%),radial-gradient(700px_260px_at_85%_100%,rgba(45,212,191,0.18),transparent_50%)]"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto flex max-w-6xl flex-col gap-8 px-6 py-12 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <BrandMark size="sm" onDark />
      <p class="mt-3 max-w-sm text-sm font-semibold text-white/75">
        {site.tagline}
      </p>
    </div>
    <div class="text-sm font-semibold">
      <p>
        <a class="text-coral-300 transition hover:text-coral-200 hover:underline" href={site.url}>
          {site.url.replace('https://', '')}
        </a>
      </p>
      <p class="mt-1 text-white/70">Hecho con 🐾 para la comunidad felina</p>
    </div>
  </div>
</footer>
