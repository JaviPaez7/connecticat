---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  showWordmark?: boolean;
  /** Use on dark backgrounds (navbar overlay, footer). */
  onDark?: boolean;
}

const { size = 'md', showWordmark = true, onDark = false } = Astro.props;

const sizes = {
  sm: 'h-8 w-8',
  md: 'h-11 w-11',
  lg: 'h-16 w-16',
};

const wordSize = {
  sm: 'text-xl',
  md: 'text-2xl',
  lg: 'text-3xl',
};
---

<span class="inline-flex items-center gap-2.5">
  <img
    src="/logo.svg"
    alt=""
    width="64"
    height="64"
    class:list={[
      'shrink-0 rounded-2xl shadow-lg shadow-coral-500/30',
      sizes[size],
    ]}
    aria-hidden="true"
  />
  {
    showWordmark && (
      <span
        class:list={[
          'font-display font-bold tracking-tight',
          wordSize[size],
          onDark ? 'text-white' : 'text-ink-900',
        ]}
      >
        Connecti<span class={onDark ? 'text-coral-300' : 'text-coral-500'}>cat</span>
      </span>
    )
  }
</span>
