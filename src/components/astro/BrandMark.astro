---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  showWordmark?: boolean;
}

const { size = 'md', showWordmark = true } = Astro.props;

const sizes = {
  sm: 'h-8 w-8 text-sm',
  md: 'h-11 w-11 text-base',
  lg: 'h-16 w-16 text-2xl',
};
---

<span class="inline-flex items-center gap-2.5">
  <span
    class:list={[
      'grid place-items-center rounded-2xl bg-gradient-to-br from-coral-400 via-apricot-400 to-mint-400 text-white shadow-lg shadow-coral-300/40 animate-paw-pop',
      sizes[size],
    ]}
    aria-hidden="true"
  >
    <span class="font-display font-bold leading-none">C</span>
  </span>
  {
    showWordmark && (
      <span class="font-display text-2xl font-bold tracking-tight text-ink-900">
        Connecti<span class="text-coral-500">cat</span>
      </span>
    )
  }
</span>
